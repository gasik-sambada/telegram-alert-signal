# ─── Telegram Bot ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ─── Symbol → Chat ID + Topic Mapping ───────────────────────────────────────────
# JSON object: keys are symbol names, values are arrays of chat targets.
# Each target can include an optional topic_id for forum group threads.
#
# Format options per entry:
#   Object with topic:    {"chat_id": "-100123456789", "topic_id": 42}
#   Object without topic: {"chat_id": "-100123456789"}
#   String with topic:    "-100123456789:42"
#   String without topic: "-100123456789"
#
# Example — BTC sends to 2 different topics in the same group,
#           ETH sends to a separate group's topic:
#
SYMBOL_CHAT_MAP={"BTCUSDT.P": [{"chat_id": "-100123456789", "topic_id": 42}], "ETHUSDT.P": [{"chat_id": "-100123456789", "topic_id": 55}, {"chat_id": "-100987654321", "topic_id": 10}]}

# ─── Default Chat IDs (fallback) ────────────────────────────────────────────────
# Comma-separated targets for symbols NOT in SYMBOL_CHAT_MAP.
# Supports "chat_id:topic_id" format. Leave empty to skip unmapped symbols.
#
DEFAULT_CHAT_IDS=-100999888777:42

# ─── Security (optional) ────────────────────────────────────────────────────────
# If set, the webhook endpoint requires X-Webhook-Secret header to match.
# Leave empty to disable validation.
#
WEBHOOK_SECRET=

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ─── Auto-Trade (push to bybit-auto-trade service) ───────────────────────────────
# URL of the bybit-auto-trade service. Leave empty to disable auto-trade forwarding.
#
AUTO_TRADE_URL=http://bybit-auto-trade:9000

# JSON array of symbols that should trigger auto-trade.
# Use .P suffix for perpetual futures (matches TradingView naming).
# Both "BTCUSDT.P" and "BTCUSDT" are accepted — flexible matching is used.
# Only "open", "close_all", and "update_sl_tp" actions are forwarded.
#
AUTO_TRADE_SYMBOLS=["BTCUSDT.P","ETHUSDT.P","SOLUSDT.P"]

# Optional shared secret sent as X-Auto-Trade-Secret header to the auto-trade service.
# Must match AUTO_TRADE_SECRET in the bybit-auto-trade .env.
#
AUTO_TRADE_SECRET=

# NOTE: order_type is forwarded transparently from the TradingView alert payload.
# If TradingView sends "order_type": "Limit" or "Market" in the alert JSON, it will
# be forwarded to bybit-auto-trade. If absent, bybit-auto-trade uses its per-symbol
# default (Market by default, configurable in config/symbols.yaml).
