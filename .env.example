# ─── Telegram Bot ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ─── Symbol → Chat ID Mapping ───────────────────────────────────────────────────
# JSON object: keys are symbol names, values are arrays of Telegram chat IDs.
# Each symbol can send alerts to multiple group chats.
#
# Example:
#   BTCUSDT → sends to 2 groups
#   ETHUSDT → sends to 1 group
#
SYMBOL_CHAT_MAP={"BTCUSDT.P": ["-100123456789", "-100987654321"], "ETHUSDT.P": ["-100111222333"]}

# ─── Default Chat IDs (fallback) ────────────────────────────────────────────────
# Comma-separated list of chat IDs for symbols NOT in SYMBOL_CHAT_MAP.
# Leave empty to skip alerts for unmapped symbols.
#
DEFAULT_CHAT_IDS=-100999888777

# ─── Security (optional) ────────────────────────────────────────────────────────
# If set, the webhook endpoint requires X-Webhook-Secret header to match.
# Leave empty to disable validation.
#
WEBHOOK_SECRET=

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
